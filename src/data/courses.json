{
  "courses": [
    {
      "slug": "cybersecurity",
      "title": "Cybersecurity",
      "category": "Security",
      "blurb": "Defend systems, networks and data against modern threats.",
      "durationMonths": 3,
      "instructor": {
        "name": "David Miller",
        "title": "Senior Cyber Security Engineer"
      },
      "outcomes": [
        "Understand cybersecurity fundamentals",
        "Identify common cyber threats",
        "Apply security best practices"
      ],
      "modules": [
        {
          "id": "m1",
          "title": "Security Fundamentals",
          "lessons": [
            {
              "id": "m1-l1",
              "title": "Introduction to Cybersecurity",
              "minutes": 15,
              "body": "Learn the fundamentals of cybersecurity, why it is important, and the different types of cyber attacks that organizations face.",
              "resources": [
                {
                  "label": "Cybersecurity Basics",
                  "url": "https://www.cisa.gov/topics/cybersecurity-best-practices"
                }
              ]
            },
            {
              "id": "m1-l2",
              "title": "The CIA Triad",
              "minutes": 18,
              "body": "Understand the three core principles of information security: Confidentiality, Integrity and Availability.",
              "resources": [
                {
                  "label": "CIA Triad",
                  "url": "https://www.ibm.com/topics/cia-triad"
                }
              ]
            },
            {
              "id": "m1-l3",
              "title": "Common Security Threats",
              "minutes": 20,
              "body": "Learn about malware, phishing, ransomware, brute force attacks and social engineering.",
              "resources": [
                {
                  "label": "OWASP Top 10",
                  "url": "https://owasp.org/www-project-top-ten/"
                }
              ]
            }
          ],
          "quiz": {
            "id": "m1-q",
            "questions": [
              {
                "id": "q1",
                "prompt": "What does CIA stand for in cybersecurity?",
                "options": [
                  "Central Intelligence Agency",
                  "Confidentiality, Integrity, Availability",
                  "Cyber Internet Access",
                  "Computer Information Analysis"
                ],
                "answerIndex": 1,
                "explanation": "The CIA Triad stands for Confidentiality, Integrity and Availability."
              },
              {
                "id": "q2",
                "prompt": "Which attack tricks users into revealing sensitive information?",
                "options": ["Firewall", "Encryption", "Phishing", "Backup"],
                "answerIndex": 2,
                "explanation": "Phishing attacks deceive users into sharing passwords or sensitive data."
              }
            ]
          }
        },
        {
          "id": "m2",
          "title": "Network Security",
          "lessons": [
            {
              "id": "m2-l1",
              "title": "Firewalls",
              "minutes": 18,
              "body": "Understand how firewalls monitor and filter incoming and outgoing network traffic.",
              "resources": [
                {
                  "label": "Firewall Basics",
                  "url": "https://www.cloudflare.com/learning/ddos/glossary/firewall/"
                }
              ]
            },
            {
              "id": "m2-l2",
              "title": "VPN and Secure Communication",
              "minutes": 20,
              "body": "Learn how Virtual Private Networks encrypt internet traffic and protect user privacy.",
              "resources": [
                {
                  "label": "VPN Guide",
                  "url": "https://www.cloudflare.com/learning/access-management/what-is-a-vpn/"
                }
              ]
            },
            {
              "id": "m2-l3",
              "title": "Password Security",
              "minutes": 16,
              "body": "Learn how to create strong passwords and use multi-factor authentication.",
              "resources": [
                {
                  "label": "Password Security",
                  "url": "https://www.cisa.gov/secure-our-world/use-strong-passwords"
                }
              ]
            }
          ],
          "quiz": {
            "id": "m2-q",
            "questions": [
              {
                "id": "q1",
                "prompt": "What is the primary purpose of a firewall?",
                "options": [
                  "Increase internet speed",
                  "Block unauthorized access",
                  "Store passwords",
                  "Encrypt files"
                ],
                "answerIndex": 1,
                "explanation": "Firewalls protect networks by filtering unauthorized traffic."
              }
            ]
          }
        },
        {
          "id": "m3",
          "title": "Ethical Hacking & Best Practices",
          "lessons": [
            {
              "id": "m3-l1",
              "title": "Ethical Hacking Basics",
              "minutes": 22,
              "body": "Learn how ethical hackers identify vulnerabilities to improve security.",
              "resources": [
                {
                  "label": "Ethical Hacking Overview",
                  "url": "https://www.eccouncil.org/"
                }
              ]
            },
            {
              "id": "m3-l2",
              "title": "Security Best Practices",
              "minutes": 20,
              "body": "Learn safe browsing, software updates, backups and least privilege principles.",
              "resources": [
                {
                  "label": "Security Best Practices",
                  "url": "https://www.cisa.gov/topics/cybersecurity-best-practices"
                }
              ]
            },
            {
              "id": "m3-l3",
              "title": "Incident Response",
              "minutes": 18,
              "body": "Understand how organizations detect, respond to and recover from cyber incidents.",
              "resources": [
                {
                  "label": "Incident Response Guide",
                  "url": "https://www.nist.gov/cyberframework"
                }
              ]
            }
          ],
          "quiz": {
            "id": "m3-q",
            "questions": [
              {
                "id": "q1",
                "prompt": "Who performs authorized security testing on systems?",
                "options": [
                  "Black Hat Hacker",
                  "Ethical Hacker",
                  "Phisher",
                  "Spammer"
                ],
                "answerIndex": 1,
                "explanation": "Ethical hackers test systems with permission to improve security."
              }
            ]
          }
        }
      ]
    },

